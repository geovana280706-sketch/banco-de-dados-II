-- 4. Consultas usando JOIN para relacionar os dados

-- Consulta 1: Listar pontos turísticos com sua respectiva cidade
SELECT 
    pt.nome AS ponto_turistico,
    pt.bairro,
    c.nome AS cidade,
    c.estado
FROM pontos_turisticos pt
INNER JOIN cidades c ON pt.id_cidade = c.id_cidade;

-- Consulta 2: Mostrar detalhes completos incluindo descrição
SELECT 
    pt.nome AS ponto,
    pt.descricao,
    c.nome AS cidade,
    c.regiao
FROM pontos_turisticos pt
LEFT JOIN cidades c ON pt.id_cidade = c.id_cidade;

-- Consulta 3: Filtrar apenas pontos da cidade do Recife
SELECT 
    pt.nome,
    pt.bairro
FROM pontos_turisticos pt
INNER JOIN cidades c ON pt.id_cidade = c.id_cidade
WHERE c.nome = 'Recife';
