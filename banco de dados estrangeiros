-- 1. Criar o banco de dados
CREATE DATABASE IF NOT EXISTS turismo_recife;
USE turismo_recife;

-- 2. Criar tabelas com relacionamento por chave estrangeira

-- Tabela principal: Cidades
CREATE TABLE IF NOT EXISTS cidades (
    id_cidade INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    estado CHAR(2) NOT NULL,
    regiao VARCHAR(50) NOT NULL
);

-- Tabela secundária: Pontos Turísticos
-- Relacionada com cidades através de id_cidade
CREATE TABLE IF NOT EXISTS pontos_turisticos (
    id_ponto INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(150) NOT NULL,
    descricao TEXT,
    bairro VARCHAR(100),
    id_cidade INT,
    -- Definindo a chave estrangeira
    FOREIGN KEY (id_cidade) REFERENCES cidades(id_cidade)
        ON DELETE RESTRICT
        ON UPDATE CASCADE
);

